{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EO-FM Living Atlas candidate entry",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "review_status",
      "needs_review",
      "source_records"
    ],
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "title": {
        "type": "string"
      },
      "scope": {
        "type": "string"
      },
      "category": {
        "type": "string"
      },
      "input_modality": {
        "type": "string"
      },
      "modality_tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "architecture": {
        "type": "string"
      },
      "architecture_tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "modelling_paradigm_key": {
        "type": "string"
      },
      "modelling_paradigm": {
        "type": "string"
      },
      "downstream_tasks": {
        "type": "string"
      },
      "task_tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "training_scale": {
        "type": "string"
      },
      "access": {
        "type": "string"
      },
      "access_label": {
        "type": "string"
      },
      "paper_url": {
        "type": "string"
      },
      "code_url": {
        "type": "string"
      },
      "weights_url": {
        "type": "string"
      },
      "project_url": {
        "type": "string"
      },
      "modality_complexity_tier_key": {
        "type": "string"
      },
      "modality_complexity_tier": {
        "type": "string"
      },
      "modality_complexity_score": {
        "type": [
          "number",
          "integer",
          "null"
        ]
      },
      "reported_downstream_task_count": {
        "type": [
          "number",
          "integer",
          "null"
        ]
      },
      "reported_downstream_task_count_basis": {
        "type": "string"
      },
      "extraction_confidence": {
        "enum": [
          "high",
          "medium",
          "low",
          ""
        ]
      },
      "needs_review": {
        "type": "boolean"
      },
      "review_status": {
        "enum": [
          "candidate",
          "verified",
          "rejected",
          "needs_information"
        ]
      },
      "source_records": {
        "type": "array"
      },
      "source_evidence": {
        "type": "array"
      },
      "deduplication_keys": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "aliases": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "conflicts": {
        "type": "array"
      },
      "notes_for_reviewer": {
        "type": "string"
      }
    },
    "additionalProperties": true
  }
}
